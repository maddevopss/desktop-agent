# MADSuite Desktop Agent — Environment Example
# Source de vérité documentaire : bleeband/SYSTEME_MAD
# Ne jamais commiter de fichier .env réel.

# API Configuration
AGENT_API_URL=http://localhost:5000
AGENT_FRONTEND_URL=http://localhost:3000
AGENT_REFRESH_TIMEOUT_MS=15000

# Application
NODE_ENV=development

# Tracking defaults
AGENT_TRACKING_ENABLED=false
AGENT_CAPTURE_INTERVAL_MS=30000

# Privacy defaults
AGENT_ALLOW_BACKGROUND_WINDOWS=false
AGENT_ALLOW_SCREEN_CAPTURE=false
AGENT_ALLOW_MICROPHONE=false
AGENT_ALLOW_CAMERA=false
