{
  "name": "desktop-agent",
  "version": "2.0.0",
  "description": "electron",
  "license": "ISC",
  "author": "MAD",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "guard:gitignore": "node scripts/guard-gitignore-policy.js",
    "guard:hygiene": "node scripts/guard-repo-hygiene.js",
    "guard:desktop-agent-contract": "node scripts/guard-desktop-agent-contract.js",
    "check:syntax": "node --check main.js && node --check preload.js && node --check src/main/ipcHandlers.js && node --check src/main/windowManager.js",
    "check:desktop": "npm run guard:gitignore && npm run guard:hygiene && npm run guard:desktop-agent-contract && npm run check:syntax && npm test",
    "start:prod": "set \"AGENT_API_URL=http://localhost:5000\" && electron .",
    "build:frontend": "npm --prefix ../frontend run build",
    "prod:desktop": "npm run build",
    "cert:test": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/create-test-cert.ps1",
    "build": "npm run cert:test && npm run build:frontend && electron-builder",
    "build:ci": "electron-builder --config electron-builder.ci.json --win nsis --publish never",
    "icons:gen": "npx electron-icon-builder --input=./icon.png --output=./build --flatten"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.2",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "utils/**/*.js",
      "!**/node_modules/**"
    ],
    "passWithNoTests": true
  }
}
